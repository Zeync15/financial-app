{
  "name": "financial-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n client,server -c blue,green \"vite\" \"node --watch --import tsx/esm server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "node --watch --import tsx/esm server/index.ts",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@ant-design/icons": "^6.0.0",
    "@better-auth/drizzle-adapter": "^1.5.0",
    "@hono/node-server": "^1.13.0",
    "@neondatabase/serverless": "^1.1.0",
    "antd": "^6.0.0",
    "better-auth": "^1.5.0",
    "dayjs": "^1.11.19",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.0.0",
    "pg": "^8.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "ws": "^8.20.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^9.0.0",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.31.9",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.8.0",
    "vite": "^6.0.0"
  }
}
