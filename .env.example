# Frontend-only build — talks directly to Supabase.
# Find these in Supabase dashboard → Project Settings → API.
# The anon key is safe to expose in the client; RLS is the security boundary.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional: free Finnhub API key (https://finnhub.io) for auto-pricing US
# holdings (e.g. VGT). Without it, prices fall back to manual entry / cost basis.
VITE_FINNHUB_API_KEY=your-finnhub-key
