# Frontend-only build — talks directly to Supabase.
# Find these in Supabase dashboard → Project Settings → API.
# The anon key is safe to expose in the client; RLS is the security boundary.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Legacy (old Hono backend, kept only until the Supabase migration is verified) ──
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/financial_app
# BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
# BETTER_AUTH_URL=http://localhost:5173
